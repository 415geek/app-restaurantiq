# --- App URL (production) ---
NEXT_PUBLIC_APP_URL=https://app.restaurantiq.ai

# When request Host matches this value, "/" redirects to "/iq" (funnel-first subdomain).
NEXT_PUBLIC_FUNNEL_HOST=app.restaurantiq.ai

# --- New Supabase project (do not reuse production restaurantiq-amazon DB) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Build-time SQL migration (scripts/apply-iq-migration.cjs) is OFF by default on Vercel.
# Prefer: `supabase db push` from CI or your machine. To run migration during `build:vercel`:
# RUN_IQ_MIGRATION_ON_BUILD=true
# Postgres URI (required only if RUN_IQ_MIGRATION_ON_BUILD=true):
# Supabase → Project Settings → Database → Connection string → URI
# Example: postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-....pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- Stripe (test or live) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Webhook path: https://app.restaurantiq.ai/api/funnel/stripe/webhook
NEXT_PUBLIC_STRIPE_PRICE_USD=19
# Optional: use a Dashboard Price ID instead of inline price_data
# STRIPE_PRICE_ID=price_xxx

# --- LLM: OpenAI fallback (required if n8n URLs not set) ---
OPENAI_API_KEY=
OPENAI_IQ_MODEL=gpt-4o-mini
# Paid full report (structured LocationIQ V2 deep); defaults to gpt-4o if unset
OPENAI_IQ_FULL_MODEL=gpt-4o

# --- LLM: Xiaomi MiMo (OpenAI-compatible; IQ primary engine when IQ_PRIMARY_PROVIDER=mimo) ---
# Apply at https://platform.xiaomimimo.com/ — key often starts with sk-
# MIMO_API_KEY=
# MIMO_API_BASE=https://api.xiaomimimo.com/v1
# MIMO_IQ_PARTIAL_MODEL=mimo-v2-flash
# MIMO_IQ_FULL_MODEL=mimo-v2.5-pro
# MIMO_IQ_VERIFY_MODEL=mimo-v2.5-pro
# IQ primary: openai | mimo (default openai until Phase 2 A/B sign-off)
# IQ_PRIMARY_PROVIDER=openai
# Regenerate paid report once if completeness score below threshold (MiMo path)
# IQ_FULL_REPORT_MIN_COMPLETENESS=60
# C-5: cross-provider verify after paid report (default on; set false to disable)
# IQ_ENABLE_DUAL_VERIFY=true
# Force verify provider: openai | mimo (default: opposite of primary when both keys exist)
# IQ_VERIFY_PROVIDER=

# Google Places (optional): stored into iq_location_reports.market_data_json on free analyze
# when N8N_IQ_ANALYZE_WEBHOOK_URL is NOT set (OpenAI-only path). n8n GatherMarketData uses the same key.
# GOOGLE_MAPS_API_KEY=

# Tavily (optional): web snippets merged into market_data_json.web_research for richer paid reports.
# https://tavily.com — set on Vercel if you want automatic web research during full-report generation.
# TAVILY_API_KEY=

# --- D-Phase external data sources (added 2026-05-26) ---
# Multi-source competitor / demographics enrichment for paid LocationIQ reports.
# Without these the OpenAI path still works but degrades to Google-only + tract-suppressed ACS.

# US Census ACS — public API also works without a key, but a key raises rate limits.
# https://api.census.gov/data/key_signup.html
# CENSUS_API_KEY=

# Yelp Fusion (5000 req/day free) — populates summary.sample_competitors_yelp + competitor menus/reviews.
# https://www.yelp.com/developers/v3/manage_app
# YELP_API_KEY=

# Foursquare Places — secondary competitor source + venue categories.
# https://foursquare.com/developers/
# FOURSQUARE_API_KEY=

# Anthropic Claude — used for human-narrative analysis (demographics interpretation, market story).
# ANTHROPIC_API_KEY=
# ANTHROPIC_API_KEY_BACKUP=  # rotation buffer

# DeepSeek — high-volume cheap LLM (competitor menu/review summarization).
# Routed via lib/funnel/iq-provider-router.ts (task iq_competitor_insights) when keys present.
# DEEPSEEK_API_KEY=

# --- n8n (optional; overrides OpenAI for analyze + full report) ---
# Scheme A (recommended): set N8N_IQ_WEBHOOK_SECRET to the SAME random string on Vercel
# and on the n8n instance (Variables / env). If both N8N_IQ_WEBHOOK_SECRET and
# N8N_INTERNAL_AUTH_TOKEN are set, app + workflows use IQ secret first (same order as n8n Code).
# Prefer deleting unused vars: empty N8N_INTERNAL_AUTH_TOKEN on Vercel can still confuse operators.
# Production (n8n.c8geek.cloud) — Bearer must match n8n instance N8N_IQ_WEBHOOK_SECRET
# N8N_IQ_ANALYZE_WEBHOOK_URL=https://n8n.c8geek.cloud/webhook/iq-analyze
# N8N_IQ_FULL_REPORT_WEBHOOK_URL=https://n8n.c8geek.cloud/webhook/iq-full-report
# N8N_IQ_WEBHOOK_SECRET=<openssl rand -hex 32>
# Aliases still supported:
# N8N_ANALYZE_WEBHOOK_URL=https://n8n.c8geek.cloud/webhook/iq-analyze
# N8N_FULL_REPORT_WEBHOOK_URL=https://n8n.c8geek.cloud/webhook/iq-full-report
# N8N_INTERNAL_AUTH_TOKEN=

# --- Clerk (optional on this deploy; only if you use dashboard routes) ---
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# Production: set NEXT_PUBLIC_APP_URL so sign-in/sign-up resolve redirect_url to absolute URLs (Clerk allow-list).
# Dashboard checklist: docs/CLERK_REDIRECTS.md

# --- Admin console (single-admin lead review at /admin/login → /admin/leads) ---
# Independent of Clerk. Used to view captured leads from the IQ funnel.
# ADMIN_EMAIL=leads@your-domain
# ADMIN_PASSWORD=replace-with-strong-password
# ADMIN_SESSION_SECRET=  # openssl rand -hex 32 (falls back to SUPABASE_SERVICE_ROLE_KEY derived key if unset)
